            "description": "Target Windows ARM64 with the Visual Studio development environment. (Debug)",
            "inherits": "Windows-base",
            "architecture": {
                "value": "arm64",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Windows-ARM64-Release",
            "displayName": "Windows ARM64 Release",
            "description": "Target Windows ARM64 with the Visual Studio development environment. (Release)",
