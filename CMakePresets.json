                "microsoft.com/VisualStudioRemoteSettings/CMake/2.0": {
                    "remoteSourceRootDir": "$env{HOME}/.vs/$ms{projectDirName}"
                }
            }
        },
        {
            "name": "Windows-base",
            "description": "Target Windows with the Visual Studio development environment.",
            "hidden": true,
            "inherits": "Project-Base",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install/${presetName}",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "Windows-Debug",
            "displayName": "Windows Debug",
            "description": "Target Windows with the Visual Studio development environment. (Debug) - Platform agnostic",
            "inherits": "Windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Windows-Release",
            "displayName": "Windows Release",
            "description": "Target Windows with the Visual Studio development environment. (Release) - Platform agnostic",
            "inherits": "Windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "Windows-AMD64-Debug",
            "displayName": "Windows AMD64 Debug",
            "description": "Target Windows (64-bit x64) with the Visual Studio development environment. (Debug)",
            "inherits": "Windows-base",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
